  validate(validatorCreateTrack),   // 3. Validar datos
  createTrack                       // 4. Ejecutar
);

router.put('/:id', 
  authMiddleware,
  checkRol(['user', 'admin']),
  validate(validatorUpdateTrack),
  updateTrack
);

// Solo admin puede eliminar
router.delete('/:id',
  authMiddleware,
  checkRol(['admin']),              // Solo admin
  validate(validatorTrackId),
  deleteTrack
);

export default router;
