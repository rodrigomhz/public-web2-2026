## 1. Validación Avanzada con Zod

> 📂 **Código de ejemplo**: [`codigo/T6/src/schemas/`](../codigo/T6/src/schemas/)

En T4 y T5 vimos validación básica. Ahora profundizamos en patrones avanzados.

### 1.1 ¿Por qué Zod?

Zod es la librería de validación más popular en 2025 (~65M descargas semanales). Ventajas:

- **Declarativo**: Define validaciones de forma clara y legible
- **Sin dependencias**: Ligero y rápido
- **Composable**: Schemas reutilizables y combinables
- **Transformaciones**: Modifica datos durante validación
- **Mensajes personalizados**: Control total sobre errores

### 1.2 Validación Condicional

```javascript
import { z } from 'zod';

// Schema que valida diferente según el tipo de usuario
const createUserSchema = z.object({
  body: z.object({
    name: z.string().min(2).max(100),
    email: z.string().email(),
    password: z.string().min(8),
    userType: z.enum(['personal', 'business']),
    // Solo requerido si userType es 'business'
    companyName: z.string().optional(),
    taxId: z.string().optional()
  }).refine(
    (data) => {
      if (data.userType === 'business') {
        return data.companyName && data.companyName.length >= 2;
      }
      return true;
    },
    {
      message: 'Las cuentas business requieren nombre de empresa',
      path: ['companyName']
    }
  ).refine(
    (data) => {
      if (data.userType === 'business') {
        return data.taxId && data.taxId.length >= 8;
      }
      return true;
    },
    {
      message: 'Las cuentas business requieren CIF/NIF',
      path: ['taxId']
    }
  )
});
```

### 1.3 Transformaciones

Zod puede transformar datos durante la validación:

```javascript
const productSchema = z.object({
  body: z.object({
    // String a slug
    name: z.string()
      .trim()
      .toLowerCase()
      .transform(s => s.replace(/\s+/g, '-')),
    
    // String a número
    price: z.string()
      .transform(val => parseFloat(val))
      .refine(val => !isNaN(val), 'Debe ser un número')
      .refine(val => val > 0, 'Debe ser positivo'),
    
    // String separado por comas a array
    tags: z.string()
      .transform(val => val.split(',').map(t => t.trim()))
      .pipe(z.array(z.string().min(1))),
    
    // Fecha string a Date
    releaseDate: z.string()
      .transform(val => new Date(val))
      .refine(val => !isNaN(val.getTime()), 'Fecha no válida')
  })
});

// Input: { name: "  Mi Producto  ", price: "29.99", tags: "tech, nuevo, oferta" }
// Output: { name: "mi-producto", price: 29.99, tags: ["tech", "nuevo", "oferta"] }
```

### 1.4 Schemas Reutilizables

```javascript
// src/schemas/common.schema.js
import { z } from 'zod';

// ObjectId de MongoDB
export const objectIdSchema = z
  .string()
  .regex(/^[0-9a-fA-F]{24}$/, 'ID no válido');

// Paginación
export const paginationSchema = z.object({
  page: z.coerce.number().int().positive().default(1),
  limit: z.coerce.number().int().min(1).max(100).default(10),
  sortBy: z.string().optional(),
  order: z.enum(['asc', 'desc']).default('desc')
});

// Rango de fechas
export const dateRangeSchema = z.object({
  startDate: z.coerce.date().optional(),
  endDate: z.coerce.date().optional()
}).refine(
  (data) => {
    if (data.startDate && data.endDate) {
      return data.startDate <= data.endDate;
    }
    return true;
  },
  { message: 'startDate debe ser anterior a endDate' }
);

// Email normalizado
export const emailSchema = z
  .string()
  .email('Email no válido')
  .toLowerCase()
  .trim();

// Password seguro
export const passwordSchema = z
  .string()
  .min(8, 'Mínimo 8 caracteres')
  .regex(/[A-Z]/, 'Debe contener mayúscula')
  .regex(/[a-z]/, 'Debe contener minúscula')
  .regex(/[0-9]/, 'Debe contener número');
```

### 1.5 Composición de Schemas

```javascript
// src/schemas/user.schema.js
import { z } from 'zod';
import { objectIdSchema, emailSchema, passwordSchema, paginationSchema } from './common.schema.js';

// Schema base (campos comunes)
const userBaseSchema = z.object({
  name: z.string().min(2).max(100).trim(),
  email: emailSchema,
  age: z.number().int().min(0).max(120).optional(),
  avatar: z.string().url().optional().nullable()
});

// Crear usuario (campos requeridos + password)
export const createUserSchema = z.object({
  body: userBaseSchema.extend({
    password: passwordSchema
  })
});

// Actualizar usuario (todos opcionales)
export const updateUserSchema = z.object({
  params: z.object({ id: objectIdSchema }),
  body: userBaseSchema.partial().refine(
    (data) => Object.keys(data).length > 0,
    { message: 'Debe enviar al menos un campo' }
  )
});

// Listar usuarios (query params)
export const listUsersSchema = z.object({
  query: paginationSchema.extend({
    search: z.string().max(100).optional(),
    isActive: z.enum(['true', 'false']).transform(v => v === 'true').optional()
  })
});
```

### 1.6 Validación de Archivos

```javascript
// src/schemas/file.schema.js
import { z } from 'zod';

// Validar archivo subido (después de Multer)
export const imageFileSchema = z.object({
  fieldname: z.string(),
  originalname: z.string(),
  mimetype: z.enum(
    ['image/jpeg', 'image/png', 'image/gif', 'image/webp'],
    { errorMap: () => ({ message: 'Solo imágenes (jpeg, png, gif, webp)' }) }
  ),
  size: z.number().max(5 * 1024 * 1024, 'Máximo 5MB')
});

export const audioFileSchema = z.object({
  fieldname: z.string(),
  originalname: z.string(),
  mimetype: z.enum(
    ['audio/mpeg', 'audio/wav', 'audio/ogg'],
    { errorMap: () => ({ message: 'Solo audio (mp3, wav, ogg)' }) }
  ),
  size: z.number().max(50 * 1024 * 1024, 'Máximo 50MB')
});

// Middleware para validar archivo
export const validateFile = (schema) => (req, res, next) => {
  if (!req.file) {
    return res.status(400).json({ error: true, message: 'Archivo requerido' });
  }
  
  const result = schema.safeParse(req.file);
  
  if (!result.success) {
    return res.status(400).json({
      error: true,
      message: result.error.errors[0].message
    });
  }
  
  next();
};
```

